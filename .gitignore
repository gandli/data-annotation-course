# ==============================================
# 1. 环境和缓存
# ==============================================
.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# ==============================================
# 2. IDE 和系统文件
# ==============================================
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ==============================================
# 3. Jupyter Notebook 产物
# ==============================================
.ipynb_checkpoints/
*.nbconvert.ipynb
*.ipynb.meta/

# ==============================================
# 4. 通用脚本输出（所有试卷通用）
# ==============================================
# 分类结果文件夹
*/**/猫/
*/**/狗/
*/**/鸡/
*/**/羊/
*/**/马/
*/**/雏菊/
*/**/蒲公英/
*/**/玫瑰/
*/**/向日葵/
*/**/郁金香/
*/**/丛林/
*/**/冰川/
*/**/山/
*/**/海/
*/**/街道/

# 采集结果文件夹（含数量标注）
*/**/*（*张）/

# 清洗和分类后的数据集
*/**/清洗后进行标注的*数据集/
*/**/数据分类后的*数据集/

# ==============================================
# 5. 通用输出文件类型
# ==============================================
# 模型文件
*.h5
*.hdf5
*.ckpt
*.pb
*.pth
*.pt

# 数据文件
*.npy
*.npz
*.csv
*.json
*.txt

# 图片输出
*.png
*.jpg
*.jpeg
*.svg
*.gif

# 图表
*.pdf

# ==============================================
# 6. 例外规则 - 保留原始测试数据集
# ==============================================
!*/**/需要分类统计的*数据集/
!*/**/需要清洗标注的*数据集/
!*/**/原始*/
!*/**/source*/
